{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "azureadf26"
		},
		"archieve_blob_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'archieve_blob'"
		},
		"csv_storage_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'csv_storage'"
		},
		"db_target_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'db_target'"
		},
		"target_csv_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'target_csv'"
		},
		"text_storage_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'text_storage'"
		},
		"db_target_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "az-dbs.database.windows.net"
		},
		"db_target_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "azuredb"
		},
		"db_target_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "admins"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "azureadf26_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"archieve_blob_connectionString": {
						"value": "[parameters('archieve_blob_connectionString')]"
					},
					"csv_storage_connectionString": {
						"value": "[parameters('csv_storage_connectionString')]"
					},
					"db_target_password": {
						"value": "[parameters('db_target_password')]"
					},
					"target_csv_connectionString": {
						"value": "[parameters('target_csv_connectionString')]"
					},
					"text_storage_connectionString": {
						"value": "[parameters('text_storage_connectionString')]"
					},
					"db_target_properties_typeProperties_server": {
						"value": "[parameters('db_target_properties_typeProperties_server')]"
					},
					"db_target_properties_typeProperties_database": {
						"value": "[parameters('db_target_properties_typeProperties_database')]"
					},
					"db_target_properties_typeProperties_userName": {
						"value": "[parameters('db_target_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}